{
  "name": "@logobaker/logobaker-i18n",
  "version": "1.1.2",
  "description": "Shared i18n translation files for LogoBaker applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "locales"
  ],
  "scripts": {
    "build": "tsc",
    "validate": "node scripts/validate.js",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "keywords": [
    "i18n",
    "translations",
    "logobaker",
    "locales"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/logobaker/logobaker-i18n.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.4.0"
  }
}
